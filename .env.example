# ---- LLM provider ----
# Provider precedence: GROQ > GEMINI > ANTHROPIC > MOCK.
# Leave all keys empty to run in deterministic MOCK mode (great for tests & offline demos).

# Groq (free tier, fast open models: https://console.groq.com/keys)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (free tier via Google AI Studio: https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Anthropic / Claude (optional alternative)
ANTHROPIC_API_KEY=
MODEL_SMART=claude-sonnet-4-6
MODEL_FAST=claude-haiku-4-5-20251001

# ---- Observability (optional) ----
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=ai-interviewer

# ---- Interview behaviour ----
QUESTIONS_TARGET=4        # number of main questions before wrap-up
HARD_CAP_QUESTIONS=7      # absolute maximum
WARN_MINUTES=20           # one-time "10 min left" warning
WRAPUP_MINUTES=30         # set wrap-up flag
HARD_STOP_MINUTES=40      # emergency end -> jump to report

# ---- Voice (optional) ----
ENABLE_VOICE=false
WHISPER_MODEL=base               # tiny | base | small | medium  (bigger = better & slower)
TTS_VOICE=en-IN-NeerjaNeural     # e.g. en-US-AriaNeural, en-IN-PrabhatNeural
RECORD_SECONDS=12                # mic capture window per turn

# ---- Email / delivery ----
# If SMTP is not configured, reports are written to ./reports and "sent" to the console.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MENTOR_EMAIL=mentor@example.com
